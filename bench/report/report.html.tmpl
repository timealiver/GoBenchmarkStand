<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GoStand — Benchmark Report</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: #ffffff; color: #1a1a1a; line-height: 1.6; }
  h1 { font-size: 1.8rem; font-weight: 700; color: #111827; }
  h2 { font-size: 1.2rem; font-weight: 600; color: #374151; text-transform: uppercase; letter-spacing: .08em; margin-bottom: .75rem; }
  h3 { font-size: .85rem; font-weight: 600; color: #4b5563; margin-bottom: .35rem; text-align: center; }
  .header { background: #ffffff; border-bottom: 2px solid #e5e7eb; padding: 1.5rem 2rem; display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .badge { background: #9B30FF; color: #fff; padding: .2rem .6rem; border-radius: 9999px; font-size: .75rem; font-weight: 700; align-self: flex-start; }
  .container { max-width: 1600px; margin: 0 auto; padding: 2rem; }
  .section { margin-bottom: 3rem; }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  @media (max-width: 1200px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
  .card { background: #ffffff; border: 1px solid #e5e7eb; border-radius: .75rem; padding: 1rem; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
  .chart-wrap { position: relative; height: 280px; }
  .chart-wrap-panel { position: relative; height: 240px; }
  .meta { font-size: .8rem; color: #6b7280; margin-top: .5rem; }
  .pill { display: inline-block; padding: .1rem .5rem; border-radius: 9999px; font-size: .75rem; font-weight: 600; }
  .pill-v1 { background: rgba(0, 209, 255, .18); color: #0891b2; }
  .pill-v2 { background: rgba(255, 65, 54, .15); color: #dc2626; }
  .pill-v3 { background: rgba(155, 48, 255, .15); color: #7c3aed; }
  .pill-v4 { background: rgba(50, 205, 50, .18); color: #15803d; }
  table { width: 100%; border-collapse: collapse; font-size: .82rem; }
  th { background: #f3f4f6; color: #374151; text-align: left; padding: .5rem .6rem; font-weight: 600; border-bottom: 1px solid #e5e7eb; }
  td { padding: .4rem .6rem; border-bottom: 1px solid #f3f4f6; }
  tr:hover td { background: #fafafa; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .env-grid { display: grid; grid-template-columns: auto 1fr; gap: .25rem 1.25rem; font-size: .85rem; max-width: 52rem; }
  .env-k { color: #6b7280; }
  .env-v { color: #111827; font-family: ui-monospace, monospace; font-size: .8rem; }
  .subhead { font-size: .7rem; text-transform: uppercase; letter-spacing: .06em; color: #6b7280; padding: .35rem 0; border-bottom: 1px solid #e5e7eb; }
  code { background: #f3f4f6; padding: .1rem .35rem; border-radius: .25rem; font-size: .85em; }
</style>
</head>
<body>

<div class="header">
  <div>
    <h1>GoStand &mdash; Benchmark Report</h1>
    <p class="meta">Прогон A (графики): {{.PrimaryLabel}}</p>
    {{if .HasCompare}}<p class="meta">Прогон B (сравнение): {{.CmpLabel}}</p>{{end}}
  </div>
  <span class="badge">go test -bench</span>
</div>

<div class="container">

  <div class="section">
    <h2>Среда на момент генерации отчёта</h2>
    <div class="card">
      <div class="env-grid">
        <span class="env-k">Время генерации</span><span class="env-v">{{.Env.GeneratedAt}}</span>
        <span class="env-k">Хост</span><span class="env-v">{{.Env.Hostname}}</span>
        <span class="env-k">Go</span><span class="env-v">{{.Env.GoVersion}}</span>
        <span class="env-k">GOOS / GOARCH</span><span class="env-v">{{.Env.GOOS}} / {{.Env.GOARCH}}</span>
        <span class="env-k">CPU (логических)</span><span class="env-v">{{.Env.NumCPU}}</span>
        <span class="env-k">GOMAXPROCS</span><span class="env-v">{{.Env.GOMAXPROCS}}</span>
        <span class="env-k">github.com/bytedance/sonic</span><span class="env-v">{{.Env.SonicVersion}}</span>
      </div>
      <p class="meta" style="margin-top:1rem">На Windows V4 (Sonic) часто работает в режиме совместимости без SIMD-ядра; для сопоставимости с Linux прогоняйте бенчмарки там или в WSL2/Docker. Подробнее — в README репозитория.</p>
    </div>
  </div>

  <div class="section">
    <h2>Версии обработчиков</h2>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:.5rem">
      <div><span class="pill pill-v1">V1</span> &nbsp;Baseline — encoding/json без пулов</div>
      <div><span class="pill pill-v2">V2</span> &nbsp;Pools — sync.Pool + capacity hints</div>
      <div><span class="pill pill-v3">V3</span> &nbsp;Flat structs — pointer-free + unsafe zero-copy</div>
      <div><span class="pill pill-v4">V4</span> &nbsp;Sonic — bytedance/sonic + flat structs</div>
    </div>
    <p class="meta" style="margin-top:.75rem">{{.ChartNote}}</p>
  </div>

  <div class="section">
    <h2>Латентность (ns/op) по размеру пейлоада</h2>
    <p class="meta" style="margin-bottom:1rem">Отдельная ось Y на каждом графике.</p>
    <div class="grid-4">
      {{range .LatencyPanels}}
      <div class="card">
        <h3>{{.Title}}</h3>
        <div class="chart-wrap-panel"><canvas id="{{.CanvasID}}"></canvas></div>
      </div>
      {{end}}
    </div>
  </div>

  {{if .HasCompare}}{{if .DeltaNs1k}}
  <div class="section">
    <h2>Сравнение прогонов: Δ времени (1k событий)</h2>
    <p class="meta" style="margin-bottom:1rem">Процент изменения медианы ns/op: (Прогон B − Прогон A) / Прогон A. Отрицательное значение — быстрее во втором прогоне.</p>
    <div class="card" style="max-width:720px">
      <div class="chart-wrap"><canvas id="{{.DeltaNs1k.CanvasID}}"></canvas></div>
    </div>
  </div>
  {{end}}{{end}}

  <div class="section">
    <h2>Аллокации и память — 1k событий (прогон A)</h2>
    <div class="grid-2">
      <div class="card">
        <h3 style="text-align:left">allocs/op</h3>
        <div class="chart-wrap"><canvas id="allocs1k"></canvas></div>
      </div>
      <div class="card">
        <h3 style="text-align:left">B/op</h3>
        <div class="chart-wrap"><canvas id="bytes1k"></canvas></div>
      </div>
    </div>
  </div>

  <div class="section">
    <h2>Масштабирование (прогон A)</h2>
    <div class="grid-2">
      <div class="card">
        <h3 style="text-align:left">allocs/op по размеру пейлоада</h3>
        <div class="chart-wrap"><canvas id="allocsGrouped"></canvas></div>
      </div>
      <div class="card">
        <h3 style="text-align:left">B/op по размеру пейлоада</h3>
        <div class="chart-wrap"><canvas id="bytesGrouped"></canvas></div>
      </div>
    </div>
  </div>

  <div class="section">
    <h2>Сводная таблица</h2>
    {{if .HasCompare}}
    <p class="meta" style="margin-bottom:.75rem">Прогон A — файл <code>-in</code> (на нём же строятся графики), прогон B — <code>-cmp</code>. Колонка Δ: процент изменения B относительно A; для времени и аллокаций отрицательное значение означает ускорение или меньше аллокаций во втором прогоне.</p>
    {{else}}
    <p class="meta" style="margin-bottom:.75rem">Медианы по сериям замеров <code>go test -bench</code>.</p>
    {{end}}
    <div class="card" style="overflow-x:auto">
      <table>
        <thead>
          {{if .HasCompare}}
          <tr>
            <th rowspan="2">Версия</th>
            <th rowspan="2">Размер</th>
            <th colspan="3" class="num subhead">ms/op</th>
            <th colspan="3" class="num subhead">allocs/op</th>
            <th colspan="3" class="num subhead">KB/op</th>
          </tr>
          <tr>
            <th class="num">A</th><th class="num">B</th><th class="num">Δ</th>
            <th class="num">A</th><th class="num">B</th><th class="num">Δ</th>
            <th class="num">A</th><th class="num">B</th><th class="num">Δ</th>
          </tr>
          {{else}}
          <tr>
            <th>Версия</th>
            <th>Размер</th>
            <th class="num">ms/op</th>
            <th class="num">allocs/op</th>
            <th class="num">KB/op</th>
          </tr>
          {{end}}
        </thead>
        <tbody>
          {{if .HasCompare}}
          {{range .TableRows}}
          <tr>
            <td>{{.Version}}</td>
            <td>{{.Size}}</td>
            <td class="num">{{.MsOp}}</td>
            <td class="num">{{.MsOpB}}</td>
            <td class="num">{{.DeltaMs}}</td>
            <td class="num">{{.AllocsOp}}</td>
            <td class="num">{{.AllocsOpB}}</td>
            <td class="num">{{.DeltaAllocs}}</td>
            <td class="num">{{.KbOp}}</td>
            <td class="num">{{.KbOpB}}</td>
            <td class="num">{{.DeltaKb}}</td>
          </tr>
          {{end}}
          {{else}}
          {{range .TableRows}}
          <tr>
            <td>{{.Version}}</td>
            <td>{{.Size}}</td>
            <td class="num">{{.MsOp}}</td>
            <td class="num">{{.AllocsOp}}</td>
            <td class="num">{{.KbOp}}</td>
          </tr>
          {{end}}
          {{end}}
        </tbody>
      </table>
    </div>
  </div>

</div>

<script>
Chart.defaults.color = '#374151';
Chart.defaults.borderColor = '#e5e7eb';

const vColors = [
  'rgba(0, 209, 255, 0.92)',
  'rgba(255, 65, 54, 0.92)',
  'rgba(155, 48, 255, 0.92)',
  'rgba(50, 205, 50, 0.92)',
];

const gridMinor = 'rgba(0, 0, 0, 0.06)';
const axisTitle = '#6b7280';

function makeGroupedChart(id, labels, datasets, yLabel, xLabel) {
  new Chart(document.getElementById(id), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: datasets.map((d, i) => ({
        label: d.label,
        data: d.values,
        backgroundColor: d.color || vColors[i % vColors.length],
        borderRadius: 4,
      }))
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: 'top', labels: { color: '#374151', font: { size: 11 } } },
      },
      scales: {
        x: {
          title: { display: !!xLabel, text: xLabel, color: axisTitle },
          ticks: { color: '#4b5563' },
          grid: { color: gridMinor },
        },
        y: {
          title: { display: true, text: yLabel, color: axisTitle },
          ticks: { color: '#4b5563' },
          grid: { color: gridMinor },
          beginAtZero: true,
        },
      },
    },
  });
}

function makeBarChart(id, labels, values, colors, yLabel) {
  new Chart(document.getElementById(id), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{ data: values, backgroundColor: colors, borderRadius: 6 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: '#4b5563' }, grid: { color: gridMinor } },
        y: {
          title: { display: true, text: yLabel, color: axisTitle },
          ticks: { color: '#4b5563' },
          grid: { color: gridMinor },
          beginAtZero: true,
        },
      },
    },
  });
}

{{if .HasCompare}}{{if .DeltaNs1k}}
new Chart(document.getElementById('{{.DeltaNs1k.CanvasID}}'), {
  type: 'bar',
  data: {
    labels: {{toJSStrings .DeltaNs1k.Labels}},
    datasets: [{
      data: {{toJS .DeltaNs1k.Values}},
      backgroundColor: {{toJSStrings .DeltaNs1k.Colors}},
      borderRadius: 6,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
      x: { ticks: { color: '#4b5563' }, grid: { color: gridMinor } },
      y: {
        title: { display: true, text: 'Δ %', color: axisTitle },
        grid: { color: gridMinor },
        ticks: { color: '#4b5563', callback: v => v + '%' },
      },
    },
  },
});
{{end}}{{end}}

{{range .LatencyPanels}}
makeBarChart('{{.CanvasID}}',
  {{toJSStrings .Labels}},
  {{toJS .Values}},
  {{toJSStrings .Colors}},
  'ns/op'
);
{{end}}

makeBarChart('allocs1k',
  {{toJSStrings .Allocs1k.Labels}},
  {{toJS .Allocs1k.Values}},
  {{toJSStrings .Allocs1k.Colors}},
  'allocs/op'
);

makeBarChart('bytes1k',
  {{toJSStrings .Bytes1k.Labels}},
  {{toJS .Bytes1k.Values}},
  {{toJSStrings .Bytes1k.Colors}},
  'B/op'
);

makeGroupedChart('allocsGrouped',
  {{toJSStrings .AllocsGrouped.Labels}},
  [{{range .AllocsGrouped.Datasets}}{label: "{{.Label}}", values: {{toJS .Values}}, color: "{{.Color}}"},{{end}}],
  'allocs/op', 'Размер пейлоада'
);

makeGroupedChart('bytesGrouped',
  {{toJSStrings .BytesGrouped.Labels}},
  [{{range .BytesGrouped.Datasets}}{label: "{{.Label}}", values: {{toJS .Values}}, color: "{{.Color}}"},{{end}}],
  'B/op', 'Размер пейлоада'
);
</script>
</body>
</html>
